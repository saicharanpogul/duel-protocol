# ─── Solana ────────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WS_URL=wss://api.devnet.solana.com

# ─── PostgreSQL ────────────────────────────────
DATABASE_URL=postgresql://duel:duel@localhost:5432/duel

# ─── Cranker ───────────────────────────────────
CRANKER_KEYPAIR=./cranker-keypair.json
POLL_INTERVAL_MS=5000
DRY_RUN=false

# ─── Server ────────────────────────────────────
PORT=3000

# ─── Indexer ───────────────────────────────────
BACKFILL_LIMIT=1000
SYNC_INTERVAL_MS=60000
