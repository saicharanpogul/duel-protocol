{
  "name": "duel-protocol",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "packageManager": "bun@1.2.4",
  "workspaces": [
    "app",
    "sdk",
    "scripts"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:app": "turbo run dev --filter=@duel-protocol/app",
    "build": "turbo run build",
    "build:app": "turbo run build --filter=@duel-protocol/app",
    "build:sdk": "turbo run build --filter=@duel-protocol/sdk",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w",
    "clean": "turbo run clean",
    "cranker": "bun run scripts/cranker.ts",
    "test": "anchor test",
    "test:skip-build": "anchor test --skip-build"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@meteora-ag/dynamic-bonding-curve-sdk": "^1.5.5"
  },
  "devDependencies": {
    "@solana/spl-token": "^0.4.0",
    "@solana/web3.js": "^1.95.0",
    "@types/bn.js": "^5.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^9.0.0",
    "chai": "^4.3.4",
    "mocha": "^9.0.3",
    "prettier": "^2.6.2",
    "ts-mocha": "^10.0.0",
    "turbo": "^2.4.4",
    "typescript": "^5.7.3"
  }
}
